# Vanetza repo directory - relative to build container
VROOT=/tool-build
VHOME=/vanetza

# Boost build vars
BOOST_MAJOR_VERSION=1
BOOST_MINOR_VERSION=90
BOOST_BUILD_DIR=boost_${BOOST_MAJOR_VERSION}_${BOOST_MINOR_VERSION}_0
BOOST_TARFILE=${BOOST_BUILD_DIR}.tar.gz
BOOST_INSTALL_DIR=${VROOT}/boost

# Locate OpenSSL root directory
if [[ "$(which openssl)" == "" ]]; then
  echo "Install openssl before proceeding."
  exit -1
fi
